{
  "expo": {
    "name": "Gather",
    "slug": "gather-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F0EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kerri.gathermobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5D6E63"
      },
      "backgroundColor": "#5D6E63",
      "package": "com.kerri.gathermobile",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "b047415b-f09c-4a40-bf6d-870d99346402"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b047415b-f09c-4a40-bf6d-870d99346402"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Gather needs camera access to scan the sync QR code from your desktop."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#5D6E63"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Gather needs access to your photos to add images to your gallery."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Gather needs your location to show local weather."
        }
      ]
    ]
  }
}
